# Copy this file to .env and fill in real values before running in production.

# Long random string used to sign login tokens. Change this — anyone who knows
# it can forge logins. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Port the server listens on
PORT=3000

# Optional: only allow account registration if this key is provided in the
# X-Signup-Key header. Leave blank to allow anyone to register (fine for a
# private single-shop deployment; set this if your server is public).
SIGNUP_KEY=
